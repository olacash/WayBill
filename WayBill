<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Waybill Tracker</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div class="page-container">
    <header>
      <h1>WayBill Tracking</h1>
      <p>Request a tracking code or use your issued code to follow your goods from source to destination.</p>
      <a class="admin-link" href="admin.html">Admin dashboard</a>
    </header>

    <section class="card">
      <h2>1. Request Tracking</h2>
      <form id="requestForm">
        <div class="grid">
          <label>
            First name
            <input type="text" name="name" required />
          </label>
          <label>
            Surname
            <input type="text" name="surname" required />
          </label>
          <label>
            Phone number
            <input type="tel" name="phone" required />
          </label>
          <label>
            Email address
            <input type="email" name="email" required />
          </label>
          <label>
            Source location
            <input type="text" name="source" required />
          </label>
          <label>
            Destination location
            <input type="text" name="destination" required />
          </label>
          <label class="full-width">
            Package description
            <textarea name="packageDetails" rows="3" placeholder="E.g. 12 boxes of electronics" required></textarea>
          </label>
        </div>
        <button type="submit">Submit request</button>
      </form>
      <div id="requestMessage" class="message"></div>
    </section>

    <section class="card">
      <h2>2. Track your shipment</h2>
      <form id="trackForm">
        <div class="grid">
          <label>
            Tracking code
            <input type="text" name="code" placeholder="Leave blank if using request ID" />
          </label>
          <label>
            Request ID
            <input type="text" name="requestId" placeholder="From your request submission" />
          </label>
          <label>
            Email address
            <input type="email" name="email" required />
          </label>
        </div>
        <button type="submit">Track shipment</button>
      </form>
      <div id="trackMessage" class="message"></div>
      <div id="trackResult" class="track-result"></div>
    </section>
  </div>

  <script src="scripts.js"></script>
</body>
</html>
